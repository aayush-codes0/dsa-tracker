# DSA Tracker Server Environment Variables

# The port your server will run on (Default: 5000)
PORT=5000

# The base URL of your deployed frontend (E.g., https://dsa-tracker.vercel.app)
# Required for secure CORS in production
CLIENT_URL=http://localhost:5173

# Secret key for JWT signing. Make this a long, random string.
JWT_SECRET=your_super_secret_jwt_key_here

# Database Configuration (MySQL)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=your_db_password
DB_NAME=dsa_tracker
